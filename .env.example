# PaneBoard 환경변수 예시 — 실제 값은 .env.local에만 (git 커밋 금지)
# NEXT_PUBLIC_* 만 클라이언트에 노출되고, 나머지는 전부 서버 전용이다.

# ── Supabase (필수) ─────────────────────────────────────────────
# Supabase 프로젝트 URL (필수 — 인증·DB·Storage 전부 사용)
NEXT_PUBLIC_SUPABASE_URL=
# Supabase anon(public) 키 (필수 — RLS로 보호되는 클라이언트/SSR 접근용)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role 키 (필수 — 서버 전용, KIS 토큰 공유 캐시 등 admin 작업. 클라이언트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=

# ── 인증 (필수) ─────────────────────────────────────────────────
# 로그인 허용 이메일 1개 (필수 — 단일 사용자 게이트, proxy·/share·콜백에서 검사)
ALLOWED_EMAIL=

# ── 주식 (KIS, 선택 — 없으면 keyless fallback 시세) ─────────────
# 'kis' 지정 시에만 KIS 실시간 시세 사용 (선택 — 미지정이면 fallback)
STOCK_PROVIDER=
# 한국투자증권 앱 키 (선택 — 읽기 전용 시세, 서버 전용)
KIS_APP_KEY=
# 한국투자증권 앱 시크릿 (선택 — 서버 전용)
KIS_APP_SECRET=
# 한국투자증권 HTS ID (선택 — 실시간 구독에 필요, KIS 경로의 필수 짝)
KIS_HTS_ID=
# KIS 토큰 파일캐시 경로 재정의 (선택 — 기본: <프로젝트>/.cache, Vercel에선 tmpdir)
KIS_TOKEN_CACHE_FILE=

# ── 날씨·위치 (선택 — 없으면 keyless Open-Meteo/Nominatim) ──────
# 기상청 단기예보 API 키 (선택 — 있으면 KMA 우선, 없으면 Open-Meteo)
KMA_API_KEY=
# Kakao Local API 키 (선택 — 지오코딩/역지오코딩 우선, 동·골프장 정확도↑)
KAKAO_LOCAL_API_KEY=
# Kakao REST 키 레거시 변수명 (선택 — KAKAO_LOCAL_API_KEY와 동일 키, 호환용)
KAKAO_REST_API_KEY=

# ── 뉴스 (선택 — 없으면 Google News RSS fallback) ────────────────
# 네이버 오픈API 클라이언트 ID (선택 — 뉴스 검색)
NAVER_CLIENT_ID=
# 네이버 오픈API 클라이언트 시크릿 (선택)
NAVER_CLIENT_SECRET=

# ── 번역 (선택 — 없으면 keyless Google gtx/MyMemory) ────────────
# DeepL API 키 (선택 — 있으면 DeepL 우선)
DEEPL_API_KEY=

# ── AI (선택) ───────────────────────────────────────────────────
# Anthropic API 키 (선택 — '지인 일정 정리' 위젯의 약속 추출, 없으면 503 안내)
ANTHROPIC_API_KEY=

# ── 개발 도구 (선택) ────────────────────────────────────────────
# Supabase DB 비밀번호 (선택 — _workspace RLS 검증 스크립트 전용, 앱 미사용)
SUPABASE_DB_PASSWORD=
